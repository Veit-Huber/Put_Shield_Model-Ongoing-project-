# Put-Shield API Keys
# Copy this file to .env and fill in your actual keys.
# Never commit .env to version control.

# FRED API key — free from https://fred.stlouisfed.org/docs/api/api_key.html
# Required for: macro_regime signal (Stage 4) --> not implemented yet
FRED_API_KEY=your_fred_api_key_here

# Financial Modeling Prep (FMP) API key — optional, improves financetoolkit data
# Required for: financetoolkit Altman Z cross-check --> not implemented yet
# Free tier available at https://financialmodelingprep.com/developer/docs/
FMP_API_KEY=your_fmp_api_key_here

# No key required for: yfinance, edgartools, py_vollib
